# ─── STRIPE ───────────────────────────────────────────────────
# Your secret key — NEVER commit the real value to git
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Webhook secret — get this from Stripe Dashboard → Webhooks
# after you add the endpoint URL
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ─── APP ──────────────────────────────────────────────────────
# URL of your React frontend (for CORS)
# e.g. https://your-chores-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Port (Railway sets this automatically)
PORT=3001
